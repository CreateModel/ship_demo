{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/chat.js": {
      "regions": ["hkg1"]
    },
    "api/speech.js": {
      "regions": ["hkg1"],
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/data/:path*", "destination": "/data/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
